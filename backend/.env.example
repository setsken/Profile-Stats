# PostgreSQL — point this at the existing Railway "postgres-yo-b" service.
# In Railway, add a Variable Reference to postgres-yo-b.DATABASE_URL instead of pasting credentials.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Shared with Stats Editor backend so JWTs issued there are accepted here.
JWT_SECRET=

# Stats Editor backend URL (used for remote subscription checks via /api/subscription/status).
STATS_EDITOR_API_URL=https://stats-editor-production.up.railway.app

# xAI key for the /api/verdict AI proxy (re-use the same key as Stats Editor).
XAI_API_KEY=

# Secret used by the legacy farmed-models sync uploader.
FARMED_SYNC_KEY=

# Server config
NODE_ENV=production
PORT=3000
